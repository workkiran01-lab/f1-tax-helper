# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Groq (server-side only — never prefix with VITE_)
GROQ_API_KEY=gsk_...

# Upstash Redis (server-side only)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# App secret — must match VITE_APP_SECRET on client
APP_SECRET=generate_a_random_32char_string
VITE_APP_SECRET=same_value_as_APP_SECRET

# Optional
VITE_SENTRY_DSN=https://...
